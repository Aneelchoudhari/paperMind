# ─── LLM Provider ───────────────────────────────────────────────
# "openai" or "gemini" or "nvidia"
LLM_PROVIDER=nvidia

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Gemini (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# NVIDIA NIM (if LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-405b-instruct


# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=papermind
POSTGRES_PASSWORD=papermind_secret
POSTGRES_DB=papermind
DATABASE_URL=postgresql+asyncpg://papermind:papermind_secret@localhost:5432/papermind

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ChromaDB ────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Storage ─────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ─── Auth (JWT) ──────────────────────────────────────────────────
# Must be at least 32 characters — change in production!
SECRET_KEY=change-me-in-production-min-32-chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Embedding model ─────────────────────────────────────────────
# Options: sentence-transformers/all-MiniLM-L6-v2 (384-dim, fast)
#          BAAI/bge-base-en-v1.5 (768-dim, higher quality, slower)
# CRITICAL: Do not change after first ingestion — requires full re-index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Rate limiting ───────────────────────────────────────────────
QA_RATE_LIMIT_PER_HOUR=30
MAX_UPLOAD_SIZE_MB=50
